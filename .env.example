# Copy to `.env` and fill in real values. `.env` is gitignored.

# Kaggle API credentials (get from https://www.kaggle.com/settings/account → "Create New Token")
KAGGLE_USERNAME=
KAGGLE_KEY=

# Where the local PaySim CSV lives (default: ./data/raw)
DATA_DIR=./data/raw

# FastAPI service config
GRAPHSAGE_API_HOST=0.0.0.0
GRAPHSAGE_API_PORT=8000
